        RowBox[{"(", 
         RowBox[{"2", 
          RowBox[{"Sqrt", "[", "3", "]"}]}], ")"}]}], " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"2", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"\[Alpha]", "+", 
               RowBox[{"\[Eta]", "^", "2"}], "-", "1"}], ")"}], "^", "2"}], "-", 
            RowBox[{"12", "\[Alpha]"}]}], "]"}]}], "-", 
         RowBox[{"2", "\[Alpha]"}], "+", 
         RowBox[{"\[Eta]", "^", "2"}], "+", "2"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rpHelper", " ", "=", " ", 
     RowBox[{"rcHelper", "-", "\[Eta]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "We", " ", "first", " ", "expand", " ", "both", " ", "in", " ", 
      "\[Eta]"}], ",", " ", 
     RowBox[{
     "then", " ", "reexpand", " ", "the", " ", "coefficients", " ", "in", " ",
       "\[Alpha]", " ", "to", " ", "obtain", " ", "the", " ", "desired", " ", 
      "double", " ", 
      RowBox[{"expansion", ".", " ", "In"}], " ", "principle"}], ",", " ", 
     RowBox[{
      RowBox[{
      "we", " ", "only", " ", "need", " ", "to", " ", "expand", " ", 
       "everything", " ", "up", " ", "to", " ", "O", 
       RowBox[{"(", "\[Alpha]", ")"}], " ", "since", " ", "we", " ", "are", " ",
        "limited", " ", "by", " ", "the", " ", "expresions", " ", "for", " ", 
       "the", " ", "\[Lambda]"}], "-", 
      RowBox[{"expansions", " ", "given", " ", 
       RowBox[{"in", " ", "[", "5", "]"}], " ", "which", " ", "are", " ", 
       "equally", "\n", "only", " ", "given", " ", "up", " ", "to", " ", "O", 
       RowBox[{"(", "\[Alpha]", ")"}]}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"rpHelperinEta", " ", "=", " ", 
     RowBox[{"Series", "[", 
      RowBox[{"rpHelper", ",", " ", 
       RowBox[{"{", 
        RowBox[{"\[Eta]", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"rpHelperinEtaAlpha", " ", "=", " ", 
     RowBox[{"Series", "[", 
      RowBox[{"rpHelperinEta", ",", " ", 
       RowBox[{"{", 
        RowBox[{"\[Alpha]", ",", " ", "0", ",", " ", "2"}], "}"}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
      "We", " ", "simply", " ", "substitute", " ", "the", " ", "expressions", 
       " ", "obtained", " ", "for", " ", "r_"}], "+", " ", 
      RowBox[{
      "to", " ", "obtain", " ", "the", " ", "continued", " ", "fraction", " ",
        "equation", " ", "as", " ", "a", " ", "double", " ", "expansion", " ",
        "in", " ", "\[Alpha]", " ", "and", " ", 
       RowBox[{"\[Eta]", ".", " ", "The"}], " ", "expression", " ", "is", " ",
        "stored", " ", "in", " ", "a", " ", "file"}]}], ",", " ", 
     RowBox[{
     "such", " ", "that", " ", "it", " ", "does", " ", "not", " ", "have", " ",
       "to", " ", "be", " ", "recalculated", " ", "every", " ", 
      RowBox[{"time", "."}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Clear", "[", "newRecurrence", "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"newcacheFile", " ", "=", " ", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", " ", 
        RowBox[{"StringJoin", "[", 
         RowBox[{"\"\<AlphaContinuedFractionDepth\>\"", ",", " ", 
          RowBox[{"ToString", "[", "cfDepth", "]"}], ",", 
          " ", "\"\<.mx\>\""}], "]"}]}], "}"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"FileExistsQ", "[", "newcacheFile", "]"}], ",", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "If", " ", "the", " ", "file", " ", "already", " ", "exists"}], ",", 
        " ", 
        RowBox[{
        "the", " ", "continued", " ", "fraction", " ", "equation", " ", "is", 
         " ", "loaded", " ", "from", " ", 
         RowBox[{"there", "."}]}]}], "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{"Get", "[", "newcacheFile", "]"}], ";", "\n", "  ", 
       RowBox[{
       "Print", 
        "[", "\"\<[Sec 8] Loaded cached \[Alpha]-recurrence from disk.\>\"", 
        "]"}]}], ",", "\n", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "If", " ", "the", " ", "continued", " ", "fraction", " ", "equation", 
         " ", "is", " ", "not", " ", "found"}], ",", " ", 
        RowBox[{
        "it", " ", "is", " ", "calculated", " ", "by", " ", "substitution", " ",
          "and", " ", "then", " ", "stored", " ", "to", " ", "the", " ", 
         "new", " ", 
         RowBox[{"file", ".", " ", "This"}], " ", "step", " ", "takes", " ", 
         RowBox[{"ca", ".", " ", "2"}], " ", 
         RowBox[{"minutes", "."}]}]}], "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{
       "Print", 
        "[", "\"\<[Sec 8] No cache found. Assembling \[Alpha]-recurrence...\>\
\"", "]"}], ";", "\n", "  ", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"newRecurrence", " ", "=", " ", 
          RowBox[{"Series", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Normal", "[", "recurrence", "]"}], " ", "/.", " ", 
             RowBox[{"rp", " ", "->", " ", 
              RowBox[{"Normal", "[", "rpHelperinEtaAlpha", "]"}]}]}], ",", 
            " ", 
            RowBox[{"{", 
             RowBox[{"\[Eta]", ",", " ", "0", ",", " ", "expansionOrder"}], 
             "}"}]}], "]"}]}], ";"}], "*)"}], "\n", "  ", 
       RowBox[{"newRecurrence", " ", "=", " ", 
        RowBox[{
         RowBox[{"Normal", "[", "recurrence", "]"}], " ", "/.", " ", 
         RowBox[{"rp", " ", "->", " ", "rpHelperinEtaAlpha"}]}]}], ";", "\n", 
       "  ", 
       RowBox[{"DumpSave", "[", 
        RowBox[{"newcacheFile", ",", " ", "newRecurrence"}], "]"}], ";", "\n",
        "  ", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<[Sec 8] Computed and cached \[Alpha]-recurrence to \>\"",
          ",", " ", "newcacheFile"}], "]"}], ";"}]}], "\n", "]"}], ";"}], 
   "\n", "\n", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<[Sec 8] Recurrence in \[Alpha] assembled.\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<[Sec 8]   ByteCount: \>\"", ",", " ", 
      RowBox[{"ByteCount", "[", "newRecurrence", "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<[Sec 8]   LeafCount: \>\"", ",", " ", 
      RowBox[{"LeafCount", "[", "newRecurrence", "]"}]}], "]"}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "We", " ", "collect", " ", "exactly", " ", "the", " ", "same", " ", 
      "information", " ", "and", " ", "run", " ", "the", " ", "same", " ", 
      "diagnostic", " ", "as", " ", "in", " ", "the", " ", "previous", " ", 
      "section", " ", "for", " ", "the", " ", "r_"}], "+", " ", 
     RowBox[{"case", "."}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"newcoeffList", " ", "=", " ", 
     RowBox[{"newRecurrence", "[", 
      RowBox[{"[", "3", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"newordMin", "   ", "=", " ", 
     RowBox[{"newRecurrence", "[", 
      RowBox[{"[", "4", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"newordMax", "    ", "=", " ", 
     RowBox[{"newRecurrence", "[", 
      RowBox[{"[", "5", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"newden", "     ", "=", " ", 
     RowBox[{"newRecurrence", "[", 
      RowBox[{"[", "6", "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<[Sec 8]   Post-omega Laurent range: eta^\>\"", ",", " ", 
      RowBox[{"newordMin", "/", "newden"}], ",", "\n", 
      "      ", "\"\< ... eta^\>\"", ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"newordMax", " ", "-", " ", "1"}], ")"}], "/", "newden"}], ",",
       "\n", "      ", "\"\<   (#stored coeffs = \>\"", ",", " ", 
      RowBox[{"Length", "[", "newcoeffList", "]"}], ",", " ", "\"\<)\>\""}], 
     "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Per", "-", "eta", "-", 
     RowBox[{
     "order", " ", "symbol", " ", "map", " ", "for", " ", "cascade", " ", 
      "planning"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<[Sec 8]   Per-eta-order symbol map:\>\"", "]"}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"Do", "[", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"exp", " ", "=", " ", 
            RowBox[{
             RowBox[{"newordMin", "/", "newden"}], " ", "+", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"idx", " ", "-", " ", "1"}], ")"}], "/", 
              "newden"}]}]}], ",", "\n", "        ", 
           RowBox[{"c", " ", "=", " ", 
            RowBox[{"newcoeffList", "[", 
             RowBox[{"[", "idx", "]"}], "]"}]}]}], "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<          eta^\>\"", ",", " ", 
            RowBox[{"PaddedForm", "[", 
             RowBox[{"exp", ",", " ", "2"}], "]"}], ",", "\n", 
            "          ", "\"\<  bytes=\>\"", ",", " ", 
            RowBox[{"PaddedForm", "[", 
             RowBox[{
              RowBox[{"ByteCount", "[", "c", "]"}], ",", " ", "8"}], "]"}], ",",
             "\n", "          ", "\"\<  | oB0=\>\"", ",", " ", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"!", 
               RowBox[{"FreeQ", "[", 
                RowBox[{"c", ",", " ", "omegaBar0"}], "]"}]}], ",", 
              " ", "\"\<Y\>\"", ",", " ", "\"\<.\>\""}], "]"}], ",", "\n", 
            "          ", "\"\<  oB1=\>\"", ",", " ", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"!", 
               RowBox[{"FreeQ", "[", 
                RowBox[{"c", ",", " ", "omegaBar1"}], "]"}]}], ",", 
              " ", "\"\<Y\>\"", ",", " ", "\"\<.\>\""}], "]"}], ",", "\n", 
            "          ", "\"\<  oB2=\>\"", ",", " ", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"!", 
               RowBox[{"FreeQ", "[", 
                RowBox[{"c", ",", " ", "omegaBar2"}], "]"}]}], ",", 
              " ", "\"\<Y\>\"", ",", " ", "\"\<.\>\""}], "]"}], ",", "\n", 
            "          ", "\"\<  nu0=\>\"", ",", " ", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"!", 
               RowBox[{"FreeQ", "[", 
                RowBox[{"c", ",", " ", "\[Nu]0"}], "]"}]}], ",", 
              " ", "\"\<Y\>\"", ",", " ", "\"\<.\>\""}], "]"}], ",", "\n", 
            "          ", "\"\<  nu1=\>\"", ",", " ", 
            RowBox[{"If", "[", 
             RowBox[{
