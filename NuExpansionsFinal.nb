Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "\n", "   ", 
    RowBox[{
     RowBox[{"Section", " ", "1"}], " ", "-", " ", 
     RowBox[{
     "Exact", " ", "symbolic", " ", "expressions", " ", "in", " ", "terms", " ",
       "of", " ", "r_C", " ", "and", " ", "r_"}], "+"}], "\n", "   ", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "==="}], 
   " ", "*)"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
     "This", " ", "cell", " ", "obtains", " ", "symbolic", " ", "expressions",
       " ", "for", " ", "all", " ", "necessary", " ", "quantities", " ", "in",
       " ", "terms", " ", "of", " ", "r_"}], "+", " ", 
     RowBox[{"and", " ", "r_C"}]}], ",", " ", 
    RowBox[{
     RowBox[{"cf", ".", " ", "thesis"}], " ", "section", " ", "2.1"}]}], 
   "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<[Sec 1] Setting L = 1, solving for a^2 and M...\>\"", 
     "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Horizon", " ", "function", " ", "with", " ", "L"}], " ", "=", 
     " ", "1"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Deltar", "[", 
      RowBox[{"r_", ",", " ", "a_", ",", " ", "M_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"r", "^", "2"}], " ", "+", " ", 
         RowBox[{"a", "^", "2"}]}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"r", "^", "2"}]}], ")"}]}], " ", "-", " ", 
      RowBox[{"2", " ", "M", " ", "r"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "The", " ", "resulting", " ", "system", " ", "is", " ", "linear", " ", 
      "in", " ", "M"}], ",", " ", 
     RowBox[{"so", " ", "that", " ", "no", " ", "branch", " ", "issues", " ", 
      RowBox[{"arise", ".", " ", "For"}], " ", "derivations", " ", 
      RowBox[{"cf", ".", " ", "thesis"}], " ", "section", " ", "2.1"}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"LsqSym", "  ", "=", " ", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"asqSym", "  ", "=", " ", 
     RowBox[{"rp", " ", "rc", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"rp", "^", "2"}], " ", "+", " ", 
           RowBox[{"rp", " ", "rc"}], " ", "+", " ", 
           RowBox[{"rc", "^", "2"}]}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"1", " ", "+", " ", 
         RowBox[{"rp", " ", "rc"}]}], ")"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"MSym", "    ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"rp", "^", "2"}], " ", "+", " ", "asqSym"}], ")"}], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", " ", "-", " ", 
