Cell[CellGroupData[{

Cell["III. \[Nu] - Expansions", "Chapter",
 CellChangeTimes->{{3.992924874295216*^9, 
  3.99292489556948*^9}},ExpressionUUID->"9fbbdfcc-e345-4c46-9967-\
5a0f6171a144"],

Cell["\<\
In  this chapter, the coefficients in the expansion \[Nu] = \[Nu]0 + \[Nu]1 \
\[Eta] + O(\[Eta]^2) are extracted from the continued fraction equation. This \
is done by organizing the continued fraction equation in powers of \[Eta], \
and requiring the coefficient of each power to vanish independently. 

Two different types of coefficients are obtained: 
- In IIIa, we simply extract the coefficients via the outlined procedure, \
which are then a function of r_+. In these expressions, \[Lambda]s_i is left \
symbolic since no expressions for them are known in terms of r_+. 
- In IIIb, we want to insert the coefficients given in [5] for the \
\[Lambda]-expansion. These are given as additional expansions in \[Alpha]. \
For this reason, in IIIb, we reexpress the entire continued fraction equation \
in terms of \[Alpha] and thus extract coefficients which are functions of \
\[Alpha]. These can then be compared to the coefficients in the expansions of \
the RHS of the QNM condition, i.e. of \[Theta]_C - \[Theta]_+. 

After a first calculation, the continued fraction equation is stored in a \
separate file. Thus, when first running the notebook, one needs to first \
execute chapters 1 and 2. After the separate file is obtained, this chapter \
works completely independently of the previous ones. 
\
\>", "Text",
 CellChangeTimes->{{3.992924899589732*^9, 3.99292492760399*^9}, {
  3.992924999778318*^9, 
  3.992925438792287*^9}},ExpressionUUID->"42ae9e41-a807-4fb6-b392-\
21c4d7dd2de6"],

Cell[CellGroupData[{

Cell["III.a. Extraction of coefficients as functions of r_+", "Section",
 CellChangeTimes->{{3.9929254428214006`*^9, 
  3.992925471170066*^9}},ExpressionUUID->"c2caa80a-dde9-4ef7-a50f-\
fba4cbf8d162"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "\n", "   ", 
    RowBox[{
     RowBox[{"Section", " ", 
      RowBox[{"7", "  ", "--"}], "  ", "Continued", " ", "fractions"}], " ", "+",
      " ", 
     RowBox[{"recurrence", " ", "assembly"}]}], "\n", "   ", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", "recurrence", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{"cf\[Alpha]nRnp1", ",", " ", "cf\[Gamma]nLnm1"}], "]"}], ";"}], 
   "\n", "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "This", " ", "is", " ", "the", " ", "implementation", " ", "of", " ", 
      "the", " ", "continued", " ", "fractions", " ", "R_n", " ", "and", " ", 
      "L_n", " ", 
      RowBox[{
       RowBox[{"from", " ", "[", "2", "]"}], "/", " ", "the"}], " ", 
      RowBox[{"thesis", ".", " ", "Note"}], " ", "that", " ", "the", " ", 
      "first", " ", "is", " ", "alreadly", " ", "\[Alpha]_n", " ", "*", " ", 
      "R_", 
      RowBox[{"{", 
       RowBox[{"n", "+", "1"}], "}"}]}], ",", " ", 
     RowBox[{
     "and", " ", "the", " ", "second", " ", "is", " ", "\[Gamma]_n", " ", "*",
       " ", "L_", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"n", "-", "1"}], "}"}], "."}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"cf\[Alpha]nRnp1", "[", 
      RowBox[{"n_", ",", " ", "nMax_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"cf\[Alpha]nRnp1", "[", 
       RowBox[{"n", ",", " ", "nMax"}], "]"}], " ", "=", " ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"n", " ", ">=", " ", "nMax"}], ",", " ", "0", ",", " ", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"\[Alpha]nSeriesWithAnsatz", "[", "n", "]"}]}], " ", "*", 
         " ", 
         RowBox[{
          RowBox[{"\[Gamma]nSeriesWithAnsatz", "[", 
           RowBox[{"n", " ", "+", " ", "1"}], "]"}], " ", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[Beta]nSeriesWithAnsatz", "[", 
             RowBox[{"n", " ", "+", " ", "1"}], "]"}], " ", "+", " ", 
            RowBox[{"cf\[Alpha]nRnp1", "[", 
             RowBox[{
              RowBox[{"n", " ", "+", " ", "1"}], ",", " ", "nMax"}], "]"}]}], 
           ")"}]}]}]}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"cf\[Gamma]nLnm1", "[", 
      RowBox[{"n_", ",", " ", "nMin_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"cf\[Gamma]nLnm1", "[", 
       RowBox[{"n", ",", " ", "nMin"}], "]"}], " ", "=", " ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"n", " ", "<=", " ", "nMin"}], ",", " ", "0", ",", " ", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"\[Gamma]nSeriesWithAnsatz", "[", "n", "]"}]}], " ", "*", 
         " ", 
         RowBox[{
          RowBox[{"\[Alpha]nSeriesWithAnsatz", "[", 
           RowBox[{"n", " ", "-", " ", "1"}], "]"}], " ", "/", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[Beta]nSeriesWithAnsatz", "[", 
             RowBox[{"n", " ", "-", " ", "1"}], "]"}], " ", "+", " ", 
            RowBox[{"cf\[Gamma]nLnm1", "[", 
             RowBox[{
              RowBox[{"n", " ", "-", " ", "1"}], ",", " ", "nMin"}], "]"}]}], 
           ")"}]}]}]}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<[Sec 6] Continued fractions defined.  Assembling \
recurrence...\>\"", "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"cacheFile", " ", "=", " ", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", " ", 
        RowBox[{"StringJoin", "[", 
         RowBox[{"\"\<continuedFractionDepth\>\"", ",", " ", 
          RowBox[{"ToString", "[", "cfDepth", "]"}], ",", 
          " ", "\"\<.mx\>\""}], "]"}]}], "}"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"FileExistsQ", "[", "cacheFile", "]"}], ",", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "If", " ", "the", " ", "file", " ", "already", " ", "exists"}], ",", 
        " ", 
        RowBox[{
        "the", " ", "continued", " ", "fraction", " ", "equation", " ", "is", 
         " ", "loaded", " ", "from", " ", 
         RowBox[{"there", "."}]}]}], "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{"Get", "[", "cacheFile", "]"}], ";", "\n", "  ", 
       RowBox[{
       "Print", "[", "\"\<[Sec 6] Loaded cached recurrence from disk.\>\"", 
        "]"}]}], ",", "\n", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "If", " ", "the", " ", "continued", " ", "fraction", " ", "equation", 
         " ", "is", " ", "not", " ", "found"}], ",", " ", 
        RowBox[{
        "it", " ", "is", " ", "calculated", " ", "recursively", " ", "and", " ",
          "then", " ", "stored", " ", "to", " ", "the", " ", "new", " ", 
         RowBox[{"file", "."}]}]}], "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{
       "Print", 
        "[", "\"\<[Sec 6] No cache found. Assembling recurrence...\>\"", 
        "]"}], ";", "\n", "  ", 
       RowBox[{"recurrence", " ", "=", " ", 
        RowBox[{
         RowBox[{"\[Beta]nSeriesWithAnsatz", "[", "0", "]"}], " ", "+", " ", 
         RowBox[{"cf\[Alpha]nRnp1", "[", 
          RowBox[{"0", ",", " ", "cfDepth"}], "]"}], " ", "+", " ", 
         RowBox[{"cf\[Gamma]nLnm1", "[", 
          RowBox[{"0", ",", " ", 
           RowBox[{"-", "cfDepth"}]}], "]"}]}]}], ";", "\n", "  ", 
       RowBox[{"DumpSave", "[", 
        RowBox[{"cacheFile", ",", " ", "recurrence"}], "]"}], ";", "\n", "  ", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<[Sec 6] Computed and cached recurrence to \>\"", ",", 
         " ", "cacheFile"}], "]"}], ";"}]}], "\n", "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "These", " ", "are", " ", "diagnostics", " ", "run", " ", "whether", " ", 
     "loaded", " ", "or", " ", "freshly", " ", 
     RowBox[{"computed", ".", " ", "They"}], " ", "in", " ", "particular", " ",
      "tell", " ", "us", " ", "if", " ", "the", " ", "coefficients", " ", 
     "of", " ", "the", " ", "expansions", " ", "have", " ", "found", " ", 
     "their", " ", "way", " ", "into", " ", "the", " ", "continued", " ", 
     "fraction", " ", 
     RowBox[{"equation", "."}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<[Sec 6]   Head:      \>\"", ",", " ", 
      RowBox[{"Head", "[", "recurrence", "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<[Sec 6]   ByteCount: \>\"", ",", " ", 
      RowBox[{"ByteCount", "[", "recurrence", "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<[Sec 6]   LeafCount: \>\"", ",", " ", 
      RowBox[{"LeafCount", "[", "recurrence", "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<[Sec 6]   Contains nu0/nu1/nu2: \>\"", ",", "\n", "      ", 
      RowBox[{
       RowBox[{
        RowBox[{"!", " ", 
         RowBox[{"FreeQ", "[", 
          RowBox[{"recurrence", ",", " ", "#"}], "]"}]}], " ", "&"}], " ", "/@",
        " ", 
       RowBox[{"{", 
        RowBox[{"\[Nu]0", ",", " ", "\[Nu]1", ",", " ", "\[Nu]2"}], "}"}]}]}],
      "]"}], ";"}]}]}]], "Code",
 CellChangeTimes->{
