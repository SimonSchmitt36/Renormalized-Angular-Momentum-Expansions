          "display", " ", "here", " ", "turn", " ", "out", " ", "to", " ", 
         "be", " ", "artificial"}]}]}]}], ",", " ", 
     RowBox[{"since", " ", "they", " ", "vanish", " ", "after", " ", 
      RowBox[{"simplification", ".", " ", "This"}], " ", "is", " ", 
      "expected"}], ",", " ", 
     RowBox[{"since", " ", 
      RowBox[{"e", ".", "g", ".", " ", "the"}], " ", "omegaBar0", " ", 
