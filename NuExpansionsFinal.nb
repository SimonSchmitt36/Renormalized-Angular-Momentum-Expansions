     "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "The", " ", "following", " ", "is", " ", "a", " ", "very", " ", "useful",
       " ", "diagnostic", " ", 
      RowBox[{"tool", ".", " ", "It"}], " ", "is", " ", "supposed", " ", "to",
