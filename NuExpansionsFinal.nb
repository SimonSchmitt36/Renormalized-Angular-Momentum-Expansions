Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "\n", "   ", 
    RowBox[{"Section", " ", 
     RowBox[{"3", "  ", "--"}], "  ", "Auxiliary", " ", "Functions"}], "\n", 
    "   ", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "==="}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<[Sec 3] Loading auxiliary functions...\>\"", "]"}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"KdSSeriesRules", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "We", " ", "manually", " ", "catch", " ", "inverse", " ", "powers", " ",
          "of", " ", "important", " ", "quantities", " ", "so", " ", "that", " ",
          "it", " ", "does", " ", "not", " ", "depend", " ", "on", " ", 
         "whether", " ", "Mathematica", " ", "is", " ", "capable", " ", "of", 
         " ", "correctly", " ", "finding", " ", "them"}], ";", "\n", "  ", 
        RowBox[{
        "and", " ", "also", " ", "this", " ", "does", " ", "not", " ", 
         "force", " ", "mathematica", " ", "to", " ", "take", " ", 
         RowBox[{"1", "/", "alphaSeries"}], " ", "and", " ", "recalculate", " ",
          "it", " ", "into", " ", "a", " ", 
         RowBox[{"1", "/", "eta"}], " ", "free", " ", 
         RowBox[{"series", "."}]}]}], " ", "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"Power", "[", 
         RowBox[{"\[Alpha]", ",", " ", 
          RowBox[{"-", "1"}]}], "]"}], "   ", "->", " ", 
        "invAlphaSeriesSTU"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"Power", "[", 
         RowBox[{"\[Alpha]", ",", " ", 
          RowBox[{"-", "2"}]}], "]"}], "   ", "->", " ", 
        "invAlpha2SeriesSTU"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"Power", "[", 
         RowBox[{
          RowBox[{"rp", " ", "-", " ", "rm"}], ",", "  ", 
          RowBox[{"-", "1"}]}], "]"}], "   ", "->", " ", 
        "invRpMinusRmSeries"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"Power", "[", 
         RowBox[{
          RowBox[{"rp", " ", "-", " ", "rm"}], ",", "  ", 
          RowBox[{"-", "2"}]}], "]"}], "   ", "->", " ", 
        "invRpMinusRmSqSeries"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"Power", "[", 
         RowBox[{
          RowBox[{"rp", " ", "-", " ", "rmm"}], ",", " ", 
          RowBox[{"-", "1"}]}], "]"}], "   ", "->", " ", 
        "invRpMinusRmmSeries"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"Power", "[", 
         RowBox[{
          RowBox[{"rm", " ", "-", " ", "rmm"}], ",", " ", 
          RowBox[{"-", "1"}]}], "]"}], "   ", "->", " ", 
        "invRmMinusRmmSeries"}], ",", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "We", " ", "separate", " ", "asq", " ", "and", " ", "Lsq", " ", "for",
          " ", "from", " ", "a", " ", "and", " ", "L", " ", "to", " ", "not", 
         " ", "be", " ", "dependent", " ", "on", " ", "Mathematica", " ", 
         "correctly", " ", "distinguishing", " ", "the", " ", 
         RowBox[{"powers", "."}]}], "  ", "*)"}], "\n", "  ", 
       RowBox[{"asq", "      ", "->", " ", "asqSeries"}], ",", "\n", "  ", 
       RowBox[{"Lsq", "      ", "->", " ", "LsqSeries"}], ",", "\n", "  ", 
       RowBox[{"a", "        ", "->", " ", "aSeries"}], ",", "\n", "  ", 
       RowBox[{"L", "        ", "->", " ", "LSeries"}], ",", "\n", "  ", 
       RowBox[{"M", " ", "->", " ", "MSeries"}], ",", "\n", "  ", 
       RowBox[{"\[Alpha]", " ", "->", " ", "alphaSeriesSTU"}], ",", "\n", 
       "  ", 
       RowBox[{"alpha2", "   ", "->", " ", "alpha2SeriesSTU"}], ",", "\n", 
       "  ", 
       RowBox[{"rm", "       ", "->", " ", "rmSeries"}], ",", "\n", "  ", 
       RowBox[{"rmm", "      ", "->", " ", "rmmSeries"}], ",", "\n", "  ", 
       RowBox[{"rc", "       ", "->", " ", 
        RowBox[{"rp", " ", "+", " ", "\[Eta]"}]}], ",", "\n", "  ", 
       RowBox[{"\[Omega]", " ", "->", " ", 
        RowBox[{
         RowBox[{"omegaBar0", " ", "\[Eta]"}], " ", "+", " ", 
         RowBox[{"omegaBar1", " ", 
          RowBox[{"\[Eta]", "^", "2"}]}], " ", "+", " ", 
         RowBox[{"omegaBar2", " ", 
          RowBox[{"\[Eta]", "^", "3"}]}]}]}], ",", " ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "This", " ", "is", " ", "the", " ", "QNM", " ", "expansion", " ", 
         "for", " ", "the", " ", "frequency", " ", "as", " ", "derived", " ", 
         RowBox[{
          RowBox[{"in", " ", "[", "5", "]"}], ".", " ", "The"}], " ", 
         "reason", " ", "one", " ", "has", " ", "to", " ", "insert", " ", 
         "this", " ", "to", " ", "obtain", " ", "truncating", " ", 
         "expressions", " ", "in", " ", "\[Eta]", " ", "for", " ", "the", " ",
          "continued", " ", "fraction", " ", "equation", " ", "is", " ", 
         "discussed", " ", "in", " ", "the", " ", "thesis", " ", "6.2"}], " ",
         "*)"}], "\n", "  ", 
       RowBox[{"\[Lambda]s", " ", "->", " ", 
        RowBox[{"\[Lambda]s0", " ", "+", " ", 
         RowBox[{"\[Lambda]s1", " ", "\[Eta]"}], " ", "+", " ", 
         RowBox[{"\[Lambda]s2", " ", 
          RowBox[{"\[Eta]", "^", "2"}]}]}]}]}], " ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "We", " ", "have", " ", "to", " ", "assume", " ", "that", " ", 
         "\[Lambda]", " ", "is", " ", "expandable", " ", "in", " ", 
         RowBox[{"\[Eta]", ".", " ", "At"}], " ", "QNMs"}], ",", " ", 
        RowBox[{
        "this", " ", "follows", " ", "from", " ", "the", " ", "coefficients", 
         " ", "obtained", " ", 
         RowBox[{"in", " ", "[", "5", "]"}], " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"Appendix", " ", "E"}], ")"}], "."}]}]}], "*)"}], "\n", 
      "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "This", " ", "expands", " ", "a", " ", "designated", " ", "quantity", " ",
       "up", " ", "to", " ", "expansionOrder"}], ",", " ", 
     RowBox[{
     "expresses", " ", "everything", " ", "in", " ", "terms", " ", "of", " ", 
      "rp", " ", "and", " ", "eta", " ", "and", " ", "unwraps", " ", "the", " ",
       "SeriesData", " ", "to", " ", "a", " ", "Polynomial"}]}], 
    "                   ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KdSExpand", "[", 
      RowBox[{"expr_", ",", " ", 
       RowBox[{"order_Integer", " ", ":", " ", "expansionOrder"}]}], "]"}], 
     " ", ":=", " ", 
     RowBox[{"Normal", "[", 
      RowBox[{"Series", "[", 
       RowBox[{
        RowBox[{"expr", " ", "/.", " ", "KdSSeriesRules"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"\[Eta]", ",", " ", "0", ",", " ", "order"}], "}"}]}], "]"}],
       "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Same", ",", " ", 
     RowBox[{
     "but", " ", "keep", " ", "the", " ", "SeriesData", " ", "wrapper", " ", 
      "for", " ", "further", " ", "series", " ", 
      RowBox[{"arithmetic", "."}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KdSSeries", "[", 
      RowBox[{"expr_", ",", " ", 
       RowBox[{"order_Integer", " ", ":", " ", "expansionOrder"}]}], "]"}], 
     " ", ":=", " ", 
     RowBox[{"Series", "[", 
      RowBox[{
       RowBox[{"expr", " ", "/.", " ", "KdSSeriesRules"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"\[Eta]", ",", " ", "0", ",", " ", "order"}], "}"}]}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "evaluates", " ", "any", " ", "parameter", " ", "in", " ", 
     "the", " ", "rotating", " ", "Nariai", " ", "limit"}], 
    "                          ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KdSExtremal", "[", "expr_", "]"}], " ", ":=", " ", 
     RowBox[{"reduceQ", "[", 
      RowBox[{
       RowBox[{"expr", " ", "/.", " ", "KdSSeriesRules"}], " ", "/.", " ", 
       RowBox[{"\[Eta]", " ", "->", " ", "0"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<[Sec 3] KdSExpand, KdSSeries, KdSExtremal ready.\>\"", 
     "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Probe", ":", " ", 
     RowBox[{"horizon", " ", 
      RowBox[{"condition", ".", "  ", "Deltar"}], 
      RowBox[{"(", "rp", ")"}], " ", "must", " ", "be", " ", "0", " ", "at", " ",
       "every", " ", "order", " ", "in", " ", 
      RowBox[{"eta", ".", " ", "This"}], " ", "verifies", " ", "that", " ", 
      "the", " ", "calculations", " ", "in", " ", "section", " ", "1", " ", 
      "and", " ", "expansions", " ", "in", " ", "section", " ", "2", " ", 
      "have", " ", "been", " ", "implemented", " ", 
      RowBox[{"correctly", "."}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "test1", "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"test1", " ", "=", " ", 
        RowBox[{
