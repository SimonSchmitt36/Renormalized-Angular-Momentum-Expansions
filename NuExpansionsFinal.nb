                RowBox[{"c", ",", " ", "\[Nu]1"}], "]"}]}], ",", 
              " ", "\"\<Y\>\"", ",", " ", "\"\<.\>\""}], "]"}], ",", "\n", 
            "          ", "\"\<  nu2=\>\"", ",", " ", 
            RowBox[{"If", "[", 
